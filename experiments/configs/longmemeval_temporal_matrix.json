{
  "global": {
    "data_type": "s",
    "retrieval_model_name": "multi-qa-MiniLM-L6-cos-v1",
    "k_seed": 10,
    "top_k_retrieval": 10
  },
  "experiments": [
    {
      "name": "pbr_base",
      "model_type": "PBR",
      "temporal_profile": false,
      "save_suffix": "_exp_pbr_base",
      "args": {}
    },
    {
      "name": "pbr_temporal_recency",
      "model_type": "PBR++",
      "temporal_profile": true,
      "save_suffix": "_exp_temporal_recency",
      "args": {
        "temporal_decay_lambda": 0.05,
        "temporal_util_alpha": 0.0,
        "temporal_util_bias": 0.0,
        "temporal_rerank_beta": 0.4,
        "temporal_graph_decay": 0.02,
        "short_term_blend": 0.5,
        "seed_candidate_multiplier": 4
      }
    },
    {
      "name": "pbr_temporal_recency_util",
      "model_type": "PBR++",
      "temporal_profile": true,
      "save_suffix": "_exp_temporal_recency_util",
      "args": {
        "temporal_decay_lambda": 0.05,
        "temporal_util_alpha": 4.0,
        "temporal_util_bias": 0.0,
        "temporal_rerank_beta": 0.4,
        "temporal_graph_decay": 0.02,
        "short_term_blend": 0.5,
        "seed_candidate_multiplier": 4
      }
    },
    {
      "name": "pbr_temporal_full_anchor",
      "model_type": "PBR++",
      "temporal_profile": true,
      "save_suffix": "_exp_temporal_full_anchor",
      "args": {
        "temporal_decay_lambda": 0.08,
        "temporal_util_alpha": 4.0,
        "temporal_util_bias": 0.0,
        "temporal_rerank_beta": 0.6,
        "temporal_graph_decay": 0.03,
        "short_term_blend": 0.7,
        "seed_candidate_multiplier": 6
      }
    }
  ]
}
