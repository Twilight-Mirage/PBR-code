{
  "global": {
    "run_root": "./experiments/runs/chapter4/baselines",
    "retriever": "flat-contriever",
    "granularity": "session",
    "gen_model_name": "qwen3.5-flash",
    "gen_model_alias": "qwen35-flash",
    "openai_key_env": "OPENAI_API_KEY",
    "openai_base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "topk_context": 10,
    "history_format": "json",
    "useronly": "false",
    "cot": "false",
    "con": "false",
    "merge_key_expansion_into_value": "none",
    "pgraphrag_repo": "./third_party_baselines/PGraphRAG",
    "afce_repo": "./third_party_baselines/AP-Bots",
    "lightrag_repo": "./third_party_baselines/LightRAG"
  },
  "experiments": [
    {
      "name": "naive_rag_longmemeval",
      "method": "naive_rag",
      "args": {
        "input_json": "./data/longmemeval_data/longmemeval_s_cleaned.json",
        "outfile_prefix": "naive_rag_longmemeval",
        "run_eval": true,
        "ref_json": "./data/longmemeval_data/longmemeval_s_cleaned.json",
        "eval_model": "gpt-4o-mini"
      }
    },
    {
      "name": "history_rag_longmemeval",
      "method": "history_rag",
      "args": {
        "input_json": "./data/longmemeval_data/longmemeval_s_cleaned.json",
        "retriever_type": "orig-session",
        "run_eval": true,
        "ref_json": "./data/longmemeval_data/longmemeval_s_cleaned.json",
        "eval_model": "gpt-4o-mini"
      }
    },
    {
      "name": "llmgt_oracle_longmemeval",
      "method": "llm_gt_baseline",
      "args": {
        "input_json": "./data/longmemeval_data/longmemeval_s_cleaned.json",
        "dataset_name": "LongMemEval",
        "evidence_mode": "oracle",
        "granularity": "session",
        "oracle_sanity_check": true,
        "run_eval": true,
        "ref_json": "./data/longmemeval_data/longmemeval_s_cleaned.json",
        "eval_model": "gpt-4o-mini"
      }
    },
    {
      "name": "pgraphrag_official_main",
      "method": "pgraphrag_official",
      "args": {
        "input": "./third_party_baselines/PGraphRAG/data_rank/amazon_rank/RANKING-amazon_dev_reviewText_bm25.json",
        "model": "gpt",
        "mode": ["both"],
        "k": [2]
      }
    },
    {
      "name": "afce_official_lamp4_partial",
      "method": "afce_official",
      "args": {
        "dataset": "lamp_4_dev_user",
        "top_k": 5,
        "retriever": "contriever",
        "features": ["WF", "DPF"],
        "counter_examples": 3,
        "repetition_step": 1,
        "prompt_style": "regular"
      }
    },
    {
      "name": "afce_official_lamp7_partial",
      "method": "afce_official",
      "args": {
        "dataset": "lamp_7_dev_user",
        "top_k": 5,
        "retriever": "contriever",
        "features": ["WF", "DPF"],
        "counter_examples": 3,
        "repetition_step": 1,
        "prompt_style": "regular"
      }
    },
    {
      "name": "lightrag_official_openai_demo",
      "method": "lightrag_official",
      "args": {
        "entry_script": "examples/lightrag_openai_demo.py"
      }
    }
  ]
}
