{
  "global": {
    "run_root": "./experiments/runs/dua_e2e",
    "in_file": "./data/longmemeval_data/longmemeval_s_cleaned.json",
    "ref_json": "./data/longmemeval_data/longmemeval_s_cleaned.json",
    "data_type": "s",
    "k_seed": 10,
    "top_k_retrieval": 10,
    "gen_model_name": "gpt-4o-mini-2024-07-18",
    "gen_model_alias": "gpt4o-mini",
    "openai_key_env": "OPENAI_API_KEY",
    "llm_api_key_env": "OPENAI_API_KEY",
    "llm_model": "gpt-4o-mini",
    "history_format": "json",
    "retriever_type": "flat-session",
    "topk_context": 10,
    "useronly": "false",
    "cot": "false",
    "con": "false",
    "merge_key_expansion_into_value": "none",
    "run_eval": false,
    "eval_model": "gpt-4o-mini"
  },
  "experiments": [
    {
      "name": "pbr_base",
      "model_type": "PBR",
      "temporal_profile": false,
      "cold_start_router": false,
      "explicit_profile": false,
      "save_suffix": "_exp_base",
      "args": {}
    },
    {
      "name": "pbr_temporal",
      "model_type": "PBR++",
      "temporal_profile": true,
      "cold_start_router": false,
      "explicit_profile": false,
      "save_suffix": "_exp_temporal",
      "args": {
        "temporal_decay_lambda": 0.05,
        "temporal_util_alpha": 4.0,
        "temporal_util_bias": 0.0,
        "temporal_rerank_beta": 0.4,
        "temporal_graph_decay": 0.02,
        "short_term_blend": 0.5
      }
    },
    {
      "name": "pbr_temporal_cold_explicit",
      "model_type": "PBR++",
      "temporal_profile": true,
      "cold_start_router": true,
      "explicit_profile": true,
      "save_suffix": "_exp_temporal_cold_explicit",
      "args": {
        "temporal_decay_lambda": 0.05,
        "temporal_util_alpha": 4.0,
        "temporal_util_bias": 0.0,
        "temporal_rerank_beta": 0.4,
        "temporal_graph_decay": 0.02,
        "short_term_blend": 0.5,
        "cold_start_prototype_bank": "./data/longmemeval_data/prototype_bank_longmemeval_s.json",
        "cold_start_k": 3.0,
        "cold_start_supervised_weight": 0.6,
        "cold_start_anchor_mix": 0.35,
        "cold_start_seed_profile_alpha": 0.2,
        "cold_start_rerank_alpha": 0.25,
        "cold_start_label_keys": "department,role,team",
        "explicit_profile_mix": 0.25,
        "explicit_feature_topk": 12,
        "explicit_seed_feature_alpha": 0.15,
        "explicit_rerank_alpha": 0.2,
        "contrastive_examples_k": 2,
        "contrastive_max_words": 90
      }
    }
  ]
}
